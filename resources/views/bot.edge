<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>WhatsApp Bot & Automation Manager</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
  <script>var require = { paths: { 'vs': 'https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.36.1/min/vs' } };</script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.36.1/min/vs/loader.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.36.1/min/vs/editor/editor.main.nls.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.36.1/min/vs/editor/editor.main.js"></script>
  <script src="/whatsapp-manager/resources/js/bot.js?v=3.3.0" defer></script>
  
  <style>
    body { background-color: #f8fafc; }
    .spinner { border: 3px solid rgba(255,255,255,0.3); border-top: 3px solid #fff; border-radius: 50%; width: 24px; height: 24px; animation: spin 1s linear infinite; }
    .spinner-dark { border-color: rgba(99, 102, 241, 0.2); border-top-color: #4f46e5; }
    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    .monaco-editor-container { height: calc(100vh - 200px); min-height: 400px; width: 100%; }
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    
    .custom-scrollbar::-webkit-scrollbar { width: 6px; height: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #475569; border-radius: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #64748b; }
    
    [x-cloak] { display: none !important; }
  </style>
</head>
<body class="text-slate-800 font-sans h-screen flex flex-col overflow-hidden">

  <!-- Injecting Advanced Data Schema -->
  <div id="app-data" class="hidden" data-commands="{{ commandFilesJson }}" data-modules="{{ modulesMetadataJson }}"></div>

  <div id="toast-container" class="fixed bottom-6 right-6 z-[100] flex flex-col gap-3 pointer-events-none"></div>

  <nav class="bg-slate-900 shadow-lg text-white shrink-0 relative z-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16">
        <div class="flex items-center space-x-3">
          <div class="bg-indigo-500 p-2 rounded-lg">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
          </div>
          <span class="font-bold text-lg tracking-tight">WhatsApp Orchestrator</span>
        </div>
        <div class="flex items-center space-x-2">
          <button data-action="switch-tab" data-target="clients" id="tab-clients-btn" class="px-4 py-2 rounded-md font-medium text-sm bg-indigo-600 text-white shadow-inner transition-all">Instances</button>
          <button data-action="switch-tab" data-target="editor" id="tab-editor-btn" class="px-4 py-2 rounded-md font-medium text-sm text-slate-300 hover:bg-slate-800 hover:text-white transition-all">Logic Editor</button>
        </div>
      </div>
    </div>
  </nav>

  <main id="tab-clients" class="flex-grow overflow-y-auto w-full bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 mb-8 flex flex-col md:flex-row items-center justify-between gap-6 hover:shadow-md transition-shadow">
        <div>
          <h2 class="text-xl font-bold text-slate-800 tracking-tight flex items-center">
            Deploy New Instance
            <button data-action="toggle-global-api-docs" class="ml-4 px-3 py-1 bg-emerald-100 text-emerald-800 text-xs rounded-lg font-bold hover:bg-emerald-200 transition-colors flex items-center shadow-sm">
              <svg class="w-3.5 h-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              Stable Global API
            </button>
          </h2>
          <p class="text-sm text-slate-500 mt-1">Initialize an independent WhatsApp client session.</p>
        </div>
        <form action="/whatsapp-manager/bot/add" method="POST" class="flex gap-3 w-full md:w-auto">
          <input type="text" name="clientId" placeholder="Instance ID (e.g. SalesBot)" class="flex-grow md:w-72 px-4 py-2.5 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-shadow text-sm" />
          <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2.5 rounded-xl font-medium shadow-sm transition-all active:scale-95 flex items-center justify-center whitespace-nowrap">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Deploy
          </button>
        </form>
      </div>

      <!-- Stable Global API Docs Section (Hidden by default) -->
      <div id="global-api-docs" class="hidden bg-slate-900 rounded-2xl shadow-xl mb-8 border border-slate-800 shrink-0 overflow-hidden relative">
        <div class="p-5 flex items-center justify-between border-b border-slate-800 bg-slate-800/50">
          <div class="flex items-center">
            <div class="p-2 bg-emerald-500/20 rounded-lg mr-3">
              <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <div>
              <h4 class="font-bold text-white text-base">Stable Global API Integration</h4>
              <p class="text-xs text-slate-400 mt-0.5">URLs that fallback automatically to <span class="text-emerald-400 font-semibold">ANY</span> available connected client. Guaranteed delivery.</p>
            </div>
          </div>
          <button data-action="toggle-global-api-docs" class="text-slate-400 hover:text-white bg-slate-800 hover:bg-slate-700 rounded-full p-2 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
          </button>
        </div>

        <div class="p-6 space-y-6 font-sans text-sm text-slate-300">
          <div>
            <p class="mb-2 text-slate-400 text-[10px] uppercase tracking-wider font-semibold">Stable Base Endpoint</p>
            <div class="bg-black/50 border border-slate-700 rounded-lg p-3 font-mono text-xs flex items-center overflow-x-auto">
              <span class="text-emerald-400 font-bold mr-2">POST</span>
              <span class="text-slate-200"><span class="api-base-url"></span>/whatsapp-manager/api/send</span>
            </div>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Text Msg -->
            <div>
              <p class="font-bold text-slate-200 mb-2 flex items-center"><span class="w-4 h-4 rounded-full bg-slate-800 flex items-center justify-center text-[9px] mr-2 text-emerald-400">1</span> Send Text Message</p>
              <pre class="bg-black/50 border border-slate-700 p-3 rounded-lg text-emerald-300 overflow-x-auto font-mono text-[11px] leading-relaxed">curl -X POST <span class="api-base-url"></span>/whatsapp-manager/api/send \
  -H "Content-Type: application/json" \
  -d '{
    "chatId": "1234567890@c.us",
    "message": "Hello from Global API!"
  }'</pre>
            </div>

            <!-- Media URL -->
            <div>
              <p class="font-bold text-slate-200 mb-2 flex items-center"><span class="w-4 h-4 rounded-full bg-slate-800 flex items-center justify-center text-[9px] mr-2 text-emerald-400">2</span> Send Media (via URL)</p>
              <pre class="bg-black/50 border border-slate-700 p-3 rounded-lg text-emerald-300 overflow-x-auto font-mono text-[11px] leading-relaxed">curl -X POST <span class="api-base-url"></span>/whatsapp-manager/api/send \
  -H "Content-Type: application/json" \
  -d '{
    "chatId": "1234567890@c.us",
    "filepath": "https://example.com/image.jpg",
    "caption": "Check out this image!"
  }'</pre>
            </div>
            
            <!-- File Upload -->
            <div>
              <p class="font-bold text-slate-200 mb-2 flex items-center"><span class="w-4 h-4 rounded-full bg-slate-800 flex items-center justify-center text-[9px] mr-2 text-emerald-400">3</span> Upload Local File (Document/Image)</p>
              <pre class="bg-black/50 border border-slate-700 p-3 rounded-lg text-emerald-300 overflow-x-auto font-mono text-[11px] leading-relaxed">curl -X POST <span class="api-base-url"></span>/whatsapp-manager/api/send \
  -F "chatId=1234567890@c.us" \
  -F "caption=Here is the document" \
  -F "file=@/path/to/local/file.pdf"</pre>
            </div>
            
            <!-- Voice Note -->
            <div>
              <p class="font-bold text-slate-200 mb-2 flex items-center"><span class="w-4 h-4 rounded-full bg-slate-800 flex items-center justify-center text-[9px] mr-2 text-emerald-400">4</span> Send Voice Note (Audio)</p>
              <pre class="bg-black/50 border border-slate-700 p-3 rounded-lg text-emerald-300 overflow-x-auto font-mono text-[11px] leading-relaxed">curl -X POST <span class="api-base-url"></span>/whatsapp-manager/api/send \
  -F "chatId=1234567890@c.us" \
  -F "audio=true" \
  -F "file=@/path/to/voice.ogg"</pre>
            </div>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="client-list">
        @if(!clients || clients.length === 0)
          <div class="col-span-full flex flex-col items-center justify-center py-20 bg-white rounded-2xl border-2 border-dashed border-slate-200">
            <div class="bg-slate-50 p-4 rounded-full mb-4">
              <svg class="w-12 h-12 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
            </div>
            <p class="text-slate-600 text-lg font-semibold">No Active Instances</p>
            <p class="text-slate-400 text-sm mt-1">Deploy an instance above to generate a QR code.</p>
          </div>
        @else
          @each(client in clients)
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden flex flex-col transition-all hover:shadow-lg" id="client-{{ client.clientId }}">
              
              <div class="p-6 flex-grow">
                <div class="flex justify-between items-start mb-5">
                  <h3 class="font-bold text-lg text-slate-800 truncate pr-3" title="{{ client.clientId }}">{{ client.clientId }}</h3>
                  <span class="client-status px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider whitespace-nowrap
                    {{ client.status === 'Connected' ? 'bg-green-100 text-green-700' : (client.status === 'QR Received' ? 'bg-blue-100 text-blue-700' : (client.status === 'Error' ? 'bg-red-100 text-red-700' : 'bg-amber-100 text-amber-700')) }}">
                    {{ client.status }}
                  </span>
                </div>
                
                <div class="flex justify-center mb-6 bg-slate-50 rounded-xl p-3 h-48 border border-slate-100 relative items-center shadow-inner">
                  <div class="qr-canvas flex justify-center items-center w-full h-full" id="qr-{{ client.clientId }}">
                    <div class="spinner spinner-dark"></div>
                  </div>
                </div>

                <div class="border-t border-slate-100 pt-4">
                  <div class="flex justify-between items-center mb-3">
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-wider flex items-center">
                      <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
                      Logic Modules
                    </p>
                    <button data-action="open-modal" data-client="{{ client.clientId }}" data-commands="{{ JSON.stringify(client.commandFiles) }}" class="text-xs text-indigo-600 font-semibold bg-indigo-50 px-2 py-1 rounded hover:bg-indigo-100 transition-colors">Assign</button>
                  </div>
                  <div class="flex flex-col gap-2" id="badges-{{ client.clientId }}">
                    @if(client.commandFiles.length === 0)
                      <span class="text-sm text-slate-400 italic block w-full bg-slate-50 p-2 rounded border border-slate-100 text-center">No logic assigned</span>
                    @else
                      @each(cmd in client.commandFiles)
                        <div class="flex items-center justify-between bg-slate-100 border border-slate-200 rounded-md pr-2 pl-3 py-1.5 group">
                          <span class="text-xs font-semibold text-slate-700">{{ cmd }}</span>
                          <button data-action="open-rules-modal" data-client="{{ client.clientId }}" data-command="{{ cmd }}" data-rules="{{ JSON.stringify(client.commandRules) }}" class="text-slate-400 hover:text-indigo-600 focus:outline-none transition-colors" title="Manage Rules & Exceptions">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                          </button>
                        </div>
                      @endeach
                    @endif
                  </div>
                </div>
              </div>

              <div class="bg-slate-50 p-3 border-t border-slate-200 grid grid-cols-3 gap-2 shrink-0">
                <button data-action="toggle-actions" data-client="{{ client.clientId }}" class="py-2 bg-white border border-slate-300 text-slate-700 hover:bg-slate-100 hover:text-slate-900 rounded-lg font-medium text-xs transition-all shadow-sm flex justify-center items-center">
                  <svg class="w-3.5 h-3.5 mr-1 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
                  Test MSG
                </button>
                <button data-action="toggle-api-docs" data-client="{{ client.clientId }}" class="py-2 bg-white border border-slate-300 text-slate-700 hover:bg-slate-100 hover:text-slate-900 rounded-lg font-medium text-xs transition-all shadow-sm flex justify-center items-center">
                  <svg class="w-3.5 h-3.5 mr-1 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
                  API Docs
                </button>
                <form action="/whatsapp-manager/bot/remove" method="POST" class="w-full">
                  <input type="hidden" name="clientId" value="{{ client.clientId }}" />
                  <button type="submit" class="w-full py-2 bg-white border border-red-200 text-red-600 hover:bg-red-50 hover:border-red-300 rounded-lg font-medium text-xs transition-all shadow-sm">Terminate</button>
                </form>
              </div>
              
              <div id="actions-{{ client.clientId }}" class="hidden p-4 bg-indigo-50 border-t border-indigo-100 shrink-0">
                <form class="send-message-form flex flex-col gap-3" data-client-id="{{ client.clientId }}">
                  <input type="text" name="chatId" placeholder="Target ID (e.g. 1234567890@c.us)" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none shadow-sm" required />
                  <input type="text" name="message" placeholder="Type your message..." class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none shadow-sm" required />
                  <button type="submit" class="w-full py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg font-medium text-sm transition-colors shadow-sm flex justify-center items-center">Send Now</button>
                </form>
              </div>

              <!-- Public Target API Docs Section -->
              <div id="api-docs-{{ client.clientId }}" class="hidden p-5 bg-slate-900 border-t border-slate-800 shrink-0 overflow-y-auto max-h-[400px] custom-scrollbar">
                <div class="flex items-center justify-between mb-4 border-b border-slate-700 pb-2">
                  <h4 class="font-bold text-white text-base flex items-center">
                    <svg class="w-5 h-5 mr-2 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
                    Targeted Client API
                  </h4>
                  <span class="text-xs font-mono text-slate-400 bg-slate-800 px-2 py-1 rounded">{{ client.clientId }}</span>
                </div>

                <div class="space-y-6 font-sans text-sm text-slate-300">
                  <div>
                    <p class="mb-2 text-slate-400 text-[10px] uppercase tracking-wider font-semibold">Target Endpoint</p>
                    <div class="bg-black/50 border border-slate-700 rounded-lg p-3 font-mono text-xs flex items-center overflow-x-auto">
                      <span class="text-emerald-400 font-bold mr-2">POST</span>
                      <span class="text-slate-200"><span class="api-base-url"></span>/whatsapp-manager/api/send/{{ client.clientId }}</span>
                    </div>
                  </div>

                  <!-- Text Msg -->
                  <div>
                    <p class="font-bold text-slate-200 mb-2 flex items-center"><span class="w-4 h-4 rounded-full bg-slate-800 flex items-center justify-center text-[9px] mr-2 text-indigo-400">1</span> Send Text Message</p>
                    <pre class="bg-black/50 border border-slate-700 p-3 rounded-lg text-emerald-300 overflow-x-auto font-mono text-[11px] leading-relaxed">curl -X POST <span class="api-base-url"></span>/whatsapp-manager/api/send/{{ client.clientId }} \
  -H "Content-Type: application/json" \
  -d '{
    "chatId": "1234567890@c.us",
    "message": "Hello from API!"
  }'</pre>
                  </div>

                  <!-- Media URL -->
                  <div>
                    <p class="font-bold text-slate-200 mb-2 flex items-center"><span class="w-4 h-4 rounded-full bg-slate-800 flex items-center justify-center text-[9px] mr-2 text-indigo-400">2</span> Send Media (via URL)</p>
                    <pre class="bg-black/50 border border-slate-700 p-3 rounded-lg text-emerald-300 overflow-x-auto font-mono text-[11px] leading-relaxed">curl -X POST <span class="api-base-url"></span>/whatsapp-manager/api/send/{{ client.clientId }} \
  -H "Content-Type: application/json" \
  -d '{
    "chatId": "1234567890@c.us",
    "filepath": "https://example.com/image.jpg",
    "caption": "Check out this image!"
  }'</pre>
                  </div>

                  <!-- File Upload -->
                  <div>
                    <p class="font-bold text-slate-200 mb-2 flex items-center"><span class="w-4 h-4 rounded-full bg-slate-800 flex items-center justify-center text-[9px] mr-2 text-indigo-400">3</span> Upload Local File (Document/Image)</p>
                    <pre class="bg-black/50 border border-slate-700 p-3 rounded-lg text-emerald-300 overflow-x-auto font-mono text-[11px] leading-relaxed">curl -X POST <span class="api-base-url"></span>/whatsapp-manager/api/send/{{ client.clientId }} \
  -F "chatId=1234567890@c.us" \
  -F "caption=Here is the document" \
  -F "file=@/path/to/local/file.pdf"</pre>
                  </div>

                  <!-- Voice Note -->
                  <div>
                    <p class="font-bold text-slate-200 mb-2 flex items-center"><span class="w-4 h-4 rounded-full bg-slate-800 flex items-center justify-center text-[9px] mr-2 text-indigo-400">4</span> Send Voice Note (Audio)</p>
                    <pre class="bg-black/50 border border-slate-700 p-3 rounded-lg text-emerald-300 overflow-x-auto font-mono text-[11px] leading-relaxed">curl -X POST <span class="api-base-url"></span>/whatsapp-manager/api/send/{{ client.clientId }} \
  -F "chatId=1234567890@c.us" \
  -F "audio=true" \
  -F "file=@/path/to/voice.ogg"</pre>
                  </div>

                  <!-- Edit Message -->
                  <div>
                    <p class="font-bold text-slate-200 mb-2 flex items-center"><span class="w-4 h-4 rounded-full bg-slate-800 flex items-center justify-center text-[9px] mr-2 text-indigo-400">5</span> Edit Sent Message</p>
                    <pre class="bg-black/50 border border-slate-700 p-3 rounded-lg text-emerald-300 overflow-x-auto font-mono text-[11px] leading-relaxed">curl -X POST <span class="api-base-url"></span>/whatsapp-manager/api/edit/{{ client.clientId }} \
  -H "Content-Type: application/json" \
  -d '{
    "messageId": "true_1234567890@c.us_ABCDEF1234567890",
    "content": "Updated text content!"
  }'</pre>
                  </div>

                  <!-- Params Table -->
                  <div class="mt-6">
                    <p class="font-bold text-slate-200 mb-3 border-b border-slate-700 pb-2 text-sm">Payload Parameters</p>
                    <ul class="space-y-3">
                      <li class="flex items-start">
                        <code class="text-indigo-300 bg-indigo-900/30 px-1.5 py-0.5 rounded text-[11px] font-bold mr-2 mt-0.5">chatId</code>
                        <span class="text-xs leading-relaxed"><span class="text-slate-400">(String | Array)</span> Target WhatsApp ID(s). Example: <code>123456789@c.us</code> (Direct) or <code>1234@g.us</code> (Group).</span>
                      </li>
                      <li class="flex items-start">
                        <code class="text-indigo-300 bg-indigo-900/30 px-1.5 py-0.5 rounded text-[11px] font-bold mr-2 mt-0.5">message</code>
                        <span class="text-xs leading-relaxed"><span class="text-slate-400">(String)</span> Text content of the message.</span>
                      </li>
                      <li class="flex items-start">
                        <code class="text-indigo-300 bg-indigo-900/30 px-1.5 py-0.5 rounded text-[11px] font-bold mr-2 mt-0.5">caption</code>
                        <span class="text-xs leading-relaxed"><span class="text-slate-400">(String)</span> Text attached to media messages.</span>
                      </li>
                      <li class="flex items-start">
                        <code class="text-indigo-300 bg-indigo-900/30 px-1.5 py-0.5 rounded text-[11px] font-bold mr-2 mt-0.5">filepath</code>
                        <span class="text-xs leading-relaxed"><span class="text-slate-400">(String)</span> A public URL or absolute local path to an image, video, audio, or document.</span>
                      </li>
                      <li class="flex items-start">
                        <code class="text-indigo-300 bg-indigo-900/30 px-1.5 py-0.5 rounded text-[11px] font-bold mr-2 mt-0.5">file</code>
                        <span class="text-xs leading-relaxed"><span class="text-slate-400">(File)</span> Upload a file using <code>multipart/form-data</code>.</span>
                      </li>
                      <li class="flex items-start">
                        <code class="text-indigo-300 bg-indigo-900/30 px-1.5 py-0.5 rounded text-[11px] font-bold mr-2 mt-0.5">audio</code>
                        <span class="text-xs leading-relaxed"><span class="text-slate-400">(Boolean)</span> Set to <code>true</code> to send audio as a playable Voice Note instead of a file.</span>
                      </li>
                      <li class="flex items-start">
                        <code class="text-indigo-300 bg-indigo-900/30 px-1.5 py-0.5 rounded text-[11px] font-bold mr-2 mt-0.5">mentions</code>
                        <span class="text-xs leading-relaxed"><span class="text-slate-400">(Array)</span> List of phone numbers (without <code>@c.us</code>) to ping in the message.</span>
                      </li>
                      <li class="flex items-start">
                        <code class="text-indigo-300 bg-indigo-900/30 px-1.5 py-0.5 rounded text-[11px] font-bold mr-2 mt-0.5">options</code>
                        <span class="text-xs leading-relaxed"><span class="text-slate-400">(Object)</span> Advanced configurations matching <code>whatsapp-web.js MessageSendOptions</code>.</span>
                      </li>
                    </ul>
                  </div>
                </div>
              </div>

            </div>
          @endeach
        @endif
      </div>
    </div>
  </main>

  <main id="tab-editor" class="hidden flex-grow w-full bg-slate-50 p-4 sm:p-6 lg:p-8 flex gap-6 overflow-hidden">
    <aside class="w-72 flex flex-col bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden shrink-0">
      <div class="p-4 border-b border-slate-200 bg-slate-50 flex justify-between items-center shrink-0">
        <h3 class="font-bold text-slate-800 text-sm tracking-wide uppercase">Logic Modules</h3>
        <button data-action="create-file" class="p-1.5 text-indigo-600 bg-indigo-100 hover:bg-indigo-200 rounded transition-colors shadow-sm" title="New Module">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        </button>
      </div>
      <div class="flex-grow overflow-y-auto p-3" id="editor-file-list"></div>
    </aside>

    <section class="flex-grow flex flex-col bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden relative">
      <div class="px-5 py-3 border-b border-slate-200 bg-slate-50 flex justify-between items-center shrink-0">
        <h3 class="font-mono text-sm font-semibold text-slate-600 flex items-center">
          <svg class="w-4 h-4 mr-2 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
          <span id="current-file-name">Select a module...</span>
        </h3>
        <button id="editor-save-btn" data-action="save-file" disabled class="px-5 py-2 bg-emerald-600 text-white rounded-lg font-medium text-sm shadow-sm hover:bg-emerald-700 disabled:opacity-50 disabled:cursor-not-allowed transition-all flex items-center">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"></path></svg>
          Save & Hot Reload
        </button>
      </div>
      
      <div id="monaco-container" class="monaco-editor-container bg-[#1e1e1e] flex-grow relative w-full h-full"></div>
    </section>
  </main>

  <div id="commands-modal" class="fixed inset-0 z-[60] hidden bg-slate-900/60 backdrop-blur-sm flex justify-center items-center opacity-0 transition-opacity duration-300">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg mx-4 overflow-hidden transform scale-95 transition-transform duration-300" id="commands-modal-content">
      <div class="px-6 py-5 border-b border-slate-100 flex justify-between items-center">
        <h3 class="font-bold text-xl text-slate-800">Assign Modules</h3>
        <button data-action="close-modal" class="text-slate-400 hover:text-slate-800 bg-slate-100 hover:bg-slate-200 rounded-full p-2 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <div class="p-6">
        <p class="text-sm text-slate-600 mb-5">Link logic modules to <strong id="modal-client-id-display" class="text-indigo-600 font-bold bg-indigo-50 px-2 py-0.5 rounded"></strong>. These scripts will automatically handle incoming messages for this specific client.</p>
        <form id="commands-form">
          <input type="hidden" id="modal-client-id" name="clientId">
          <div class="space-y-3 max-h-[45vh] overflow-y-auto pr-2" id="modal-checkbox-list"></div>
          <div class="mt-8 flex justify-end gap-3 pt-5 border-t border-slate-100">
            <button type="button" data-action="close-modal" class="px-5 py-2.5 bg-white border border-slate-300 text-slate-700 rounded-xl text-sm font-medium hover:bg-slate-50 transition-colors shadow-sm">Cancel</button>
            <button type="submit" class="px-6 py-2.5 bg-indigo-600 text-white rounded-xl text-sm font-medium shadow-sm hover:bg-indigo-700 transition-colors flex items-center">
              Apply Configuration
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div id="rules-modal" class="fixed inset-0 z-[70] hidden bg-slate-900/60 backdrop-blur-sm flex justify-center items-center opacity-0 transition-opacity duration-300">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-2xl mx-4 overflow-hidden transform scale-95 transition-transform duration-300 flex flex-col max-h-[85vh]" id="rules-modal-content">
      <div class="px-6 py-5 border-b border-slate-100 flex justify-between items-center shrink-0">
        <div>
          <h3 class="font-bold text-xl text-slate-800">Rules & Exceptions</h3>
          <p class="text-xs font-mono text-indigo-600 bg-indigo-50 inline-block px-2 py-0.5 rounded mt-1" id="rules-command-display"></p>
        </div>
        <button data-action="close-rules-modal" class="text-slate-400 hover:text-slate-800 bg-slate-100 hover:bg-slate-200 rounded-full p-2 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <div class="p-6 flex-grow overflow-hidden flex flex-col">
        <form id="rules-form" class="flex flex-col h-full">
          <div id="rules-chats-list" class="flex-grow overflow-y-auto pr-2">
            <!-- Dynamically populated contacts and groups -->
          </div>
          <div class="mt-6 flex justify-end gap-3 pt-5 border-t border-slate-100 shrink-0">
            <button type="button" data-action="close-rules-modal" class="px-5 py-2.5 bg-white border border-slate-300 text-slate-700 rounded-xl text-sm font-medium hover:bg-slate-50 transition-colors shadow-sm">Cancel</button>
            <button type="submit" class="px-6 py-2.5 bg-emerald-600 text-white rounded-xl text-sm font-medium shadow-sm hover:bg-emerald-700 transition-colors flex items-center">
              Save Rules
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

</body>
</html>