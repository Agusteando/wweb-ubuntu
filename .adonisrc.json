{
  "typescript": true,
  "commands": [
    "./commands",
    "@adonisjs/core/build/commands/index.js",
    "@adonisjs/repl/build/commands"
  ],
  "exceptionHandlerNamespace": "App/Exceptions/Handler",
  "aliases": {
    "App": "app",
    "Config": "config",
    "Contracts": "contracts"
  },
  "preloads": ["./start/routes", "./start/kernel"],
  "providers": [
    "@adonisjs/core",
    "@adonisjs/view",
    "./providers/BotServiceProvider"
  ],
  "aceProviders": ["@adonisjs/repl"],
  "metaFiles": [
    {
      "pattern": "resources/views/**/*.edge",
      "reloadServer": false
    },
    {
      "pattern": "resources/js/**/*.js",
      "reloadServer": false
    },
    {
      "pattern": "app/Whatsapp/Commands/**/*.ts",
      "reloadServer": false
    }
  ]
}